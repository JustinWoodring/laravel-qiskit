APP_NAME="Laravel Qiskit Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file

# IBM Quantum credentials
# Get these from https://quantum.ibm.com/account
QISKIT_API_KEY=your-ibm-quantum-api-key-here
QISKIT_SERVICE_CRN=crn:v1:bluemix:public:quantum-computing:us-east:...
QISKIT_DEFAULT_BACKEND=ibm_brisbane

# Optional overrides
# QISKIT_BASE_URL=https://us-east.quantum-computing.cloud.ibm.com
# QISKIT_POLL_INTERVAL=10
# QISKIT_POLL_MAX_ATTEMPTS=360
# QISKIT_POLL_QUEUE=quantum
