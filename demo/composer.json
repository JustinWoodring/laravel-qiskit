{
    "name": "justinwoodring/laravel-qiskit-demo",
    "description": "Demo Laravel application for the laravel-qiskit package",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Justin Woodring",
            "homepage": "https://github.com/JustinWoodring"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "justinwoodring/laravel-qiskit": "@dev"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
